# Application environment used by local Docker Compose
APP_ENV=local

# Base URL used for links/callbacks generated by the API
PUBLIC_BASE_URL=http://localhost:8000

# Explicitly opt in to local bootstrap of the seeded admin account
LOCAL_ADMIN_BOOTSTRAP_ENABLED=true

# JWT signing secret for auth tokens (use a strong secret outside local dev)
JWT_SECRET=local-dev-jwt-secret-change-before-shared-use

# Platform master key used for privileged credential operations
PLATFORM_MASTER_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=

# Primary database DSN for application persistence
POSTGRES_DSN=postgresql+psycopg://lsos:lsos@localhost:5432/lsos

# Explicit Alembic URL required by the backend migration entrypoint
DATABASE_URL=postgresql+psycopg://lsos:lsos@localhost:5432/lsos
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
